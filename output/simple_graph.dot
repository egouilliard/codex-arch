// Dependency Graph
digraph {
	graph [bgcolor="#FFFFFF" concentrate=true fontname=Arial fontsize=16 label="Dependency Graph" labelloc=t nodesep=0.5 overlap=false rankdir=LR ranksep=0.75 sep="+10" splines=polyline]
	node [fontname=Arial fontsize=12 margin="0.2,0.1" shape=box style=filled]
	edge [fontname=Arial fontsize=10]
	module_a [label="📚 module_a" color="#000000" fillcolor="#FFF9C4" shape=box style=filled]
	module_b [label="📚 module_b" color="#000000" fillcolor="#FFF9C4" shape=box style=filled]
	module_c [label="📚 module_c" color="#000000" fillcolor="#FFF9C4" shape=box style=filled]
	module_a -> module_b [color="#9E9E9E"]
	module_a -> module_c [color="#9E9E9E"]
	module_b -> module_c [color="#9E9E9E"]
}
